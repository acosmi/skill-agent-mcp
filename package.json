{
  "name": "@acosmi/skill-agent-mcp",
  "version": "1.2.0",
  "description": "MCP server exposing skill-driven agent capabilities — SKILL.md as the unified fusion layer for tools, prompt fragments, and sub-agents.",
  "license": "Apache-2.0",
  "author": "fushihua <fgfncc@gmail.com>",
  "homepage": "https://github.com/acosmi/skill-agent-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acosmi/skill-agent-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/acosmi/skill-agent-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": false
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "bin": {
    "acosmi-skill-agent-mcp": "./bin/acosmi-skill-agent-mcp",
    "acosmi-skill-agent-mcp-bun": "./bin/acosmi-skill-agent-mcp-bun"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities/index.d.ts",
      "bun": "./src/capabilities/index.ts",
      "import": "./dist/capabilities/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "bun": "./src/codegen/index.ts",
      "import": "./dist/codegen/index.js"
    },
    "./dispatch": {
      "types": "./dist/dispatch/index.d.ts",
      "bun": "./src/dispatch/index.ts",
      "import": "./dist/dispatch/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "bun": "./src/llm/index.ts",
      "import": "./dist/llm/index.js"
    },
    "./manage": {
      "types": "./dist/manage/index.d.ts",
      "bun": "./src/manage/index.ts",
      "import": "./dist/manage/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "bun": "./src/mcp/index.ts",
      "import": "./dist/mcp/index.js"
    },
    "./secrets": {
      "types": "./dist/secrets/index.d.ts",
      "bun": "./src/secrets/index.ts",
      "import": "./dist/secrets/index.js"
    },
    "./skill": {
      "types": "./dist/skill/index.d.ts",
      "bun": "./src/skill/index.ts",
      "import": "./dist/skill/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "bun": "./src/tools/index.ts",
      "import": "./dist/tools/index.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "bin/",
    "templates/",
    "examples/",
    "docs/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run typecheck && bun test && bun run build",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "start": "bun src/cli/main.ts",
    "start:built": "node bin/acosmi-skill-agent-mcp"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "skill",
    "skill-driven",
    "capability-tree",
    "anthropic",
    "claude",
    "ai-tools",
    "typescript"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^4.17.21"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "yaml": "^2.8.3",
    "zod": "^3.25.0"
  }
}
